PORT=8000
DATABASE_URL=
JWT_SECRET=
JWT_EXPIRES_IN=7d
NODE_ENV=development

# Gmail address that gets admin dashboard access (Google sign-in only). Defaults to chawkanijairi8@gmail.com if unset.
ADMIN_GOOGLE_EMAIL=
# Where new-order alerts and order-summary emails go (optional). Defaults to ADMIN_GOOGLE_EMAIL.
ADMIN_ORDER_NOTIFY_EMAIL=

# Google Sign-In — Web Client ID (same as VITE_GOOGLE_CLIENT_ID in the frontend). Required for POST /auth/google.
GOOGLE_CLIENT_ID=
# Passport Google OAuth (GET /auth/google/oauth → callback). Add redirect URI in Google Cloud Console.
GOOGLE_CLIENT_SECRET=
# Must match the authorized redirect URI, e.g. http://localhost:8000/auth/google/callback
CALLBACK_URL=
# Where the API redirects after OAuth (SPA). Either FRONTEND_URL or CLIENT_URL works.
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173
# Optional; defaults to JWT_SECRET. Used to sign the session cookie.
SESSION_SECRET=

# Bootstrap admin (optional overrides; code defaults: Admin / 123 / shawscopra.defaultadmin@gmail.com)
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_USERNAME=
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_FULL_NAME=Site Administrator

# Customer order emails & admin notifications (Gmail SMTP — use an App Password, not your login password)
# https://myaccount.google.com/apppasswords  (requires 2-Step Verification on the Google account)
GMAIL_USER=
GMAIL_APP_PASSWORD=
