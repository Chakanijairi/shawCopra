PORT=8000
DATABASE_URL=
JWT_SECRET=
JWT_EXPIRES_IN=7d
NODE_ENV=development

# Gmail address that gets admin dashboard access (Google sign-in only). Defaults to chawkanijairi8@gmail.com if unset.
ADMIN_GOOGLE_EMAIL=
# Where new-order alerts and order-summary emails go (optional). Defaults to ADMIN_GOOGLE_EMAIL.
ADMIN_ORDER_NOTIFY_EMAIL=

# Google Sign-In — Web Client ID (same as VITE_GOOGLE_CLIENT_ID in the frontend). Required for POST /auth/google.
GOOGLE_CLIENT_ID=
# Passport Google OAuth (GET /auth/google/oauth → callback). Add redirect URI in Google Cloud Console.
GOOGLE_CLIENT_SECRET=
# Must match an entry in Google Cloud → Authorized redirect URIs (exact string).
# Local:   http://localhost:8000/auth/google/callback
# Render:  https://shawcopra.onrender.com/auth/google/callback
CALLBACK_URL=
# Where the API redirects after OAuth (SPA). Either FRONTEND_URL or CLIENT_URL works.
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173

# --- Supabase Storage (product images on Render; optional locally — omit to use backend/uploads) ---
# Create bucket `products` (or override with SUPABASE_STORAGE_BUCKET), allow public read for objects.
# Files are stored at public/<filename> in the bucket; DB column image_path holds the full getPublicUrl() string.
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service_role key from Project Settings → API; server only, never expose to frontend>
# SUPABASE_STORAGE_BUCKET=products

# --- Render (production) example (set in Render Dashboard → Environment) ---
# NODE_ENV=production
# DATABASE_URL=postgresql://...supabase...  (one line only; remove duplicate keys)
# CALLBACK_URL=https://shawcopra.onrender.com/auth/google/callback
# FRONTEND_URL=https://shaw-copra.vercel.app
# CLIENT_URL=https://shaw-copra.vercel.app
# GOOGLE_CLIENT_ID=<same as VITE_GOOGLE_CLIENT_ID>
# GOOGLE_CLIENT_SECRET=<from Google Cloud>
# SESSION_SECRET=<long random string; or reuse JWT_SECRET>
# Optional; defaults to JWT_SECRET. Used to sign the session cookie.
SESSION_SECRET=

# Bootstrap admin (optional overrides; code defaults: Admin / 123 / shawscopra.defaultadmin@gmail.com)
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_USERNAME=
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_FULL_NAME=Site Administrator

# --- Gmail (fixes "Gmail is not configured" for order alerts & customer update emails) ---
#
# STEP 1 — Use a normal @gmail.com Google account (Workspace may restrict SMTP; Gmail is simplest).
#
# STEP 2 — Turn on 2-Step Verification:
#   https://myaccount.google.com/security → "2-Step Verification" → follow prompts.
#
# STEP 3 — Create an App Password (16 characters, NOT your Gmail login password):
#   https://myaccount.google.com/apppasswords
#   App name: e.g. "Shaw Copra API" → Create → copy the 16-character password.
#
# STEP 4 — Put them in THIS file (local) or Render → Environment (production), no quotes:
#   GMAIL_USER=yourshop@gmail.com
#   GMAIL_APP_PASSWORD=abcd efgh ijkl mnop
#   (Spaces in the app password are OK; the server strips them.)
#
# STEP 5 — Restart: local = stop and run `node server.js` / `npm run dev` again.
#   Render = Dashboard → your service → Manual Deploy, or change any env var and save (restarts).
#
# STEP 6 — Optional: where to send "new order" alerts (defaults to ADMIN_GOOGLE_EMAIL if unset):
#   ADMIN_ORDER_NOTIFY_EMAIL=you@gmail.com
#
# Sends FROM GMAIL_USER via smtp.gmail.com:465. Customer emails use the same sender.
GMAIL_USER=
GMAIL_APP_PASSWORD=
