# Required for “Continue with Google” (same Web Client ID as GOOGLE_CLIENT_ID on Render).
VITE_GOOGLE_CLIENT_ID=

# Backend API base URL — no trailing slash. Baked in at build time (Vite).
# Local:  http://localhost:8000
# Vercel: MUST be your public API https URL — never leave localhost for production builds or Google OAuth will fail.
#        Example: https://shawcopra.onrender.com
VITE_API_URL=http://localhost:8000

# Note: FRONTEND_URL / CLIENT_URL / CALLBACK_URL belong on the API host (Render), not here.

# --- Google Cloud → OAuth 2.0 Client (Web application) ---
# Authorized JavaScript origins (add every frontend origin you use):
#   http://localhost:5173
#   http://127.0.0.1:5173
#   https://shaw-copra.vercel.app
# Authorized redirect URIs (must match CALLBACK_URL on the API exactly):
#   http://localhost:8000/auth/google/callback
#   https://YOUR-API.onrender.com/auth/google/callback
