# Required for “Continue with Google” (same Web Client ID as GOOGLE_CLIENT_ID on Render).
VITE_GOOGLE_CLIENT_ID=

# Backend API base URL — no trailing slash.
# Local:  http://localhost:8000
# Prod:   https://shawcopra.onrender.com
VITE_API_URL=http://localhost:8000

# Note: VITE_CLIENT_URL is not used by this app. FRONTEND_URL / CLIENT_URL belong on the API (Render).

# Google Cloud → Credentials → OAuth 2.0 Client (Web application):
#   Authorized JavaScript origins:
#     http://localhost:5173
#     http://127.0.0.1:5173
#     http://localhost:4173
#     https://shaw-copra.vercel.app
#   Authorized redirect URIs (must match CALLBACK_URL on Render):
#     http://localhost:8000/auth/google/callback
#     https://shawcopra.onrender.com/auth/google/callback
