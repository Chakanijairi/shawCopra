# Same value as GOOGLE_CLIENT_ID in backend/.env (OAuth 2.0 Web client ID).
VITE_GOOGLE_CLIENT_ID=
#
# Google Cloud → Credentials → OAuth 2.0 Client (Web application):
#   Authorized JavaScript origins: http://localhost:5173  AND  http://127.0.0.1:5173
#   Authorized redirect URIs: http://localhost:8000/auth/google/callback
# Optional if API is not at http://localhost:8000
# VITE_API_URL=http://localhost:8000
